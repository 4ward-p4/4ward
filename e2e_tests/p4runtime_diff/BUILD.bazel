# =============================================================================
# bmv2 simple_switch_grpc binary build chain
# =============================================================================
#
# The diff harness needs an external implementation of P4Runtime to compare
# against. We build one from upstream source: bmv2's `simple_switch_grpc`,
# which links bmv2's data-plane (`@behavioral_model//:simple_switch_lib`,
# already built natively) against bmv2's PI integration adapter (`libbmpi`,
# also from behavioral-model — the Thrift-free alternative to PI's
# `libpi_bmv2`) and PI's P4Runtime gRPC handler (`@p4lang_pi//proto/server:piserver`).
#
# Targets live here rather than in PI or behavioral-model patches because they
# cross both modules — `simple_switch_grpc` needs PI's piserver, and PI's
# pi_server.cpp needs gnmi types from behavioral-model. Putting the rules in
# either upstream patch would create a Bzlmod dep cycle.

# ---------------------------------------------------------------------------
# bmv2's PI target adapter (libbmpi). Symbol-equivalent to PI's libpi_bmv2
# but uses bm_sim's in-process C++ API instead of Thrift IPC. This is what
# lets us avoid Apache Thrift entirely.
# ---------------------------------------------------------------------------

cc_library(
    name = "libbmpi",
    srcs = ["@behavioral_model//:libbmpi_srcs"],
    copts = [
        "-std=c++17",
        "-w",
    ],
    tags = ["manual"],
    visibility = ["//visibility:private"],
    deps = [
        "@behavioral_model//:bm_sim",
        "@behavioral_model//:bmpi_public_hdrs",
        "@behavioral_model//:simple_switch_lib",
        "@p4lang_pi//:pi",
        "@p4lang_pi//:pip4info",
    ],
)

# ---------------------------------------------------------------------------
# simple_switch_grpc: the upstream BMv2 binary. Compiled without WITH_THRIFT
# and without WITH_SYSREPO, so all Thrift / sysrepo IPC blocks preprocess
# out cleanly. Links bm_sim + libbmpi + piserver + gRPC dataplane service.
# ---------------------------------------------------------------------------

cc_binary(
    name = "simple_switch_grpc",
    srcs = ["@behavioral_model//:simple_switch_grpc_srcs"],
    copts = [
        "-std=c++17",
        "-w",
    ],
    # WORKAROUND: bm_sim_c bundles RFC-1321 MD5 with the same symbol names
    # (MD5_Init / MD5_Update / MD5_Final) as BoringSSL's crypto, which gRPC
    # transitively links. Both end up in the link; --allow-multiple-definition
    # lets the first occurrence win. Implementations are functionally identical
    # but this is brittle to the link order. Should be fixed upstream by
    # putting bm_sim_c's md5 in a private namespace.
    linkopts = ["-Wl,--allow-multiple-definition"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        ":libbmpi",
        "@behavioral_model//:bm_dataplane_interface_cc_grpc",
        "@behavioral_model//:bm_grpc_pem",
        "@behavioral_model//:bm_sim",
        "@behavioral_model//:bmpi_public_hdrs",
        "@behavioral_model//:simple_switch_lib",
        "@grpc//:grpc++",
        "@grpc//:grpc++_reflection",
        "@p4lang_pi//:pi",
        "@p4lang_pi//:pip4info",
        "@p4lang_pi//proto/frontend:pifeproto",
        "@p4lang_pi//proto/server:piserver",
    ],
)

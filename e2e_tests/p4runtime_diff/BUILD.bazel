kt_jvm_test(
    name = "P4RuntimeDiffSmokeTest",
    srcs = ["P4RuntimeDiffSmokeTest.kt"],
    data = [":simple_switch_grpc"],
    tags = ["heavy"],
    # The bmv2/PI build chain is Linux-only — PI's lib/vector.c trips the
    # newer macOS SDK's stricter -Wimplicit-function-declaration on
    # `__assert_rtn` (an Apple SDK-specific assert.h expansion). The harness's
    # purpose (cross-validate against simple_switch_grpc) is also Linux-only
    # in practice, so don't carry the macOS porting cost.
    target_compatible_with = ["@platforms//os:linux"],
    test_class = "fourward.e2e.p4runtimediff.P4RuntimeDiffSmokeTest",
    deps = [
        ":runners",
        "//bazel:runfiles",
        "//simulator:p4runtime_java_proto",
        "@fourward_maven//:io_grpc_grpc_api",
        "@fourward_maven//:junit_junit",
    ],
)


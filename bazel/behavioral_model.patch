diff -ruN a/BUILD.bazel b/BUILD.bazel
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -0,0 +1,295 @@
+# Native Bazel build for behavioral-model (BMv2).
+# Minimal build: no Thrift, no nanomsg, no debugger, no PI.
+
+load("@protobuf//bazel:cc_proto_library.bzl", "cc_proto_library")
+load("@protobuf//bazel:proto_library.bzl", "proto_library")
+load("@rules_cc//cc:defs.bzl", "cc_library")
+
+# --- System libraries ---
+# libgmp and libpcap are expected to be system-installed.
+# macOS: brew install gmp (pcap is part of the SDK).
+# Linux: apt install libgmp-dev libpcap-dev.
+# The genrules copy headers into the build tree so Bazel's include-path
+# validation doesn't reject absolute system paths.
+
+load("@grpc//bazel:cc_grpc_library.bzl", "cc_grpc_library")
+
+_GMP_SEARCH_PATHS = [
+    "/opt/homebrew/include",  # macOS (Apple Silicon Homebrew)
+    "/usr/local/include",  # macOS (Intel Homebrew)
+    "/usr/include/x86_64-linux-gnu",  # Ubuntu/Debian multiarch
+    "/usr/include",  # Linux (non-multiarch)
+]
+
+genrule(
+    name = "gen_gmp_h",
+    outs = ["system_include/gmp.h"],
+    cmd = " || ".join([
+        "([ -f {p}/gmp.h ] && cp {p}/gmp.h $@)".format(p = p)
+        for p in _GMP_SEARCH_PATHS
+    ]) + ' || { echo "ERROR: gmp.h not found -- install libgmp-dev" >&2; exit 1; }',
+    # No build inputs capture host state; must re-run every time.
+    tags = [
+        "no-cache",
+        "no-remote-cache",
+    ],
+)
+
+genrule(
+    name = "gen_gmpxx_h",
+    outs = ["system_include/gmpxx.h"],
+    cmd = " || ".join([
+        "([ -f {p}/gmpxx.h ] && cp {p}/gmpxx.h $@)".format(p = p)
+        for p in _GMP_SEARCH_PATHS
+    ]) + ' || { echo "ERROR: gmpxx.h not found -- install libgmp-dev" >&2; exit 1; }',
+    tags = [
+        "no-cache",
+        "no-remote-cache",
+    ],
+)
+
+cc_library(
+    name = "system_gmp",
+    hdrs = [
+        ":gen_gmp_h",
+        ":gen_gmpxx_h",
+    ],
+    includes = ["system_include"],
+    linkopts = [
+        "-L/opt/homebrew/lib",
+        "-lgmp",
+    ],
+)
+
+cc_library(
+    name = "system_pcap",
+    linkopts = ["-lpcap"],
+)
+
+# --- Generated headers ---
+
+genrule(
+    name = "gen_config_h",
+    outs = ["include/bm/config.h"],
+    cmd = "\n".join([
+        "cat > $@ <<'CONF'",
+        "#ifndef _INCLUDE_BM_CONFIG_H",
+        "#define _INCLUDE_BM_CONFIG_H 1",
+        "/* Generated by Bazel -- minimal build without Thrift/nanomsg/debugger. */",
+        "#define BM_HAVE_ALGORITHM 1",
+        "#define BM_HAVE_ARRAY 1",
+        "#define BM_HAVE_CASSERT 1",
+        "#define BM_HAVE_CMATH 1",
+        "#define BM_HAVE_CSTDIO 1",
+        "#define BM_HAVE_CTIME 1",
+        "#define BM_HAVE_QUEUE 1",
+        "#define BM_HAVE_STRING 1",
+        "#define BM_HAVE_SYS_STAT_H 1",
+        "#define BM_HAVE_SYS_TYPES_H 1",
+        "#define BM_HAVE_TUPLE 1",
+        "#define BM_HAVE_UNISTD_H 1",
+        "#define BM_HAVE_UNORDERED_MAP 1",
+        "#define BM_HAVE_UTILITY 1",
+        "#define BM_HAVE_VECTOR 1",
+        "#define BM_WP4_16_STACKS 1",
+        "/* Per-packet trace logging (parser transitions, table lookups, actions). */",
+        "/* Analogous to 4ward trace trees -- keep enabled for fair benchmarking. */",
+        "#define BM_LOG_DEBUG_ON 1",
+        "#define BM_LOG_TRACE_ON 1",
+        "/* BM_ELOG_ON intentionally omitted: the event logger writes a binary log */",
+        "/* to disk for offline analysis tools -- no 4ward equivalent. */",
+        "#endif",
+        "CONF",
+    ]),
+)
+
+genrule(
+    name = "gen_version_cpp",
+    srcs = ["src/bm_sim/version.cpp.in"],
+    outs = ["src/bm_sim/version.cpp"],
+    cmd = "sed 's/@BM_VERSION@/bazel-head/' $(SRCS) > $@",
+)
+
+# --- Vendored jsoncpp ---
+
+cc_library(
+    name = "jsoncpp",
+    srcs = ["third_party/jsoncpp/src/jsoncpp.cpp"],
+    hdrs = ["third_party/jsoncpp/include/jsoncpp/json.h"],
+    copts = ["-w"],
+    includes = ["third_party/jsoncpp/include"],
+)
+
+# --- Vendored spdlog (header-only) ---
+
+cc_library(
+    name = "spdlog",
+    hdrs = glob(["third_party/spdlog/bm/spdlog/**/*.h"]),
+    includes = ["third_party/spdlog"],
+    # format.h textually includes format.cc via #include "format.cc".
+    textual_hdrs = glob(["third_party/spdlog/bm/spdlog/**/*.cc"]),
+)
+
+# --- BMI (packet I/O via libpcap) ---
+
+cc_library(
+    name = "bmi",
+    srcs = [
+        "src/BMI/bmi_interface.c",
+        "src/BMI/bmi_port.c",
+    ],
+    hdrs = [
+        "src/BMI/BMI/bmi_port.h",
+        "src/BMI/bmi_interface.h",
+    ],
+    copts = ["-w"],
+    includes = ["src/BMI"],
+    deps = [":system_pcap"],
+)
+
+# --- Core BMv2 simulator library ---
+
+# C sources in bm_sim that must not receive -std=c++17.
+cc_library(
+    name = "bm_sim_c",
+    srcs = glob(["src/bm_sim/**/*.c"]),
+    copts = ["-w"],
+    textual_hdrs = glob(["src/bm_sim/**/*.h"]),
+    deps = [":system_gmp"],
+)
+
+cc_library(
+    name = "bm_sim",
+    srcs = glob(
+        [
+            "src/bm_sim/**/*.cpp",
+        ],
+        exclude = [
+            # nanomsg transport
+            "src/bm_sim/transport_nn.cpp",
+            # nanomsg packet-in device manager
+            "src/bm_sim/dev_mgr_packet_in.cpp",
+            # nanomsg debugger
+            "src/bm_sim/debugger.cpp",
+            # autoconf template -- we generate version.cpp via genrule
+            "src/bm_sim/version.cpp.in",
+        ],
+    ) + [
+        ":gen_version_cpp",
+    ],
+    hdrs = glob(["include/bm/**/*.h"]) + [":gen_config_h"],
+    copts = [
+        "-std=c++17",
+        "-w",
+    ],
+    includes = [
+        "include",
+        "src/bm_sim",
+    ],
+    # 128-bit atomics in packet.cpp need libatomic on Linux.
+    linkopts = select({
+        "@platforms//os:linux": ["-latomic"],
+        "//conditions:default": [],
+    }),
+    # Private headers in src/bm_sim/ (crc_map.h, etc.)
+    textual_hdrs = glob(["src/bm_sim/**/*.h"]),
+    visibility = ["//visibility:public"],
+    deps = [
+        ":bm_sim_c",
+        ":bmi",
+        ":jsoncpp",
+        ":spdlog",
+        ":system_gmp",
+        ":system_pcap",
+        "@boost.container",
+        "@boost.filesystem",
+        "@boost.functional",
+        "@boost.multiprecision",
+        "@boost.program_options",
+        "@boost.thread",
+        "@boost.variant",
+    ],
+)
+
+# --- simple_switch (v1model target) ---
+
+cc_library(
+    name = "simple_switch_lib",
+    srcs = [
+        "targets/simple_switch/primitives.cpp",
+        "targets/simple_switch/simple_switch.cpp",
+    ],
+    hdrs = [
+        "targets/simple_switch/register_access.h",
+        "targets/simple_switch/simple_switch.h",
+    ],
+    copts = [
+        "-std=c++17",
+        "-w",
+    ],
+    includes = ["targets/simple_switch"],
+    visibility = ["//visibility:public"],
+    deps = [":bm_sim"],
+)
+
+# --- Source filegroups for the P4Runtime diff harness ---
+# 4ward's e2e_tests/p4runtime_diff package compiles the libbmpi PI integration,
+# the dataplane_interface gRPC service, and the simple_switch_grpc binary in
+# its own tree. These filegroups expose the source files; cc_library/cc_binary
+# rules live in the consumer to avoid a Bzlmod dep cycle with @p4lang_pi.
+
+filegroup(
+    name = "libbmpi_srcs",
+    srcs = glob([
+        "PI/src/*.cpp",
+        "PI/src/*.h",
+    ]),
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "bmpi_public_hdrs",
+    hdrs = glob(["PI/bm/PI/*.h"]),
+    includes = ["PI"],
+    visibility = ["//visibility:public"],
+)
+
+filegroup(
+    name = "simple_switch_grpc_srcs",
+    srcs = [
+        "targets/simple_switch_grpc/main.cpp",
+        "targets/simple_switch_grpc/switch_runner.cpp",
+        "targets/simple_switch_grpc/switch_runner.h",
+    ],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "bm_grpc_pem",
+    hdrs = ["include/bm/bm_grpc/pem.h"],
+    strip_include_prefix = "include",
+    visibility = ["//visibility:public"],
+)
+
+# --- Dataplane gRPC service proto ---
+
+proto_library(
+    name = "bm_dataplane_interface_proto",
+    srcs = ["services/p4/bm/dataplane_interface.proto"],
+    strip_import_prefix = "services",
+    visibility = ["//visibility:public"],
+)
+
+cc_proto_library(
+    name = "bm_dataplane_interface_cc_proto",
+    visibility = ["//visibility:public"],
+    deps = [":bm_dataplane_interface_proto"],
+)
+
+cc_grpc_library(
+    name = "bm_dataplane_interface_cc_grpc",
+    srcs = [":bm_dataplane_interface_proto"],
+    grpc_only = True,
+    visibility = ["//visibility:public"],
+    deps = [":bm_dataplane_interface_cc_proto"],
+)
diff -ruN a/include/bm/bm_sim/dynamic_bitset.h b/include/bm/bm_sim/dynamic_bitset.h
--- a/include/bm/bm_sim/dynamic_bitset.h
+++ b/include/bm/bm_sim/dynamic_bitset.h
@@ -48,6 +48,13 @@
       find_lowest_bit<uint32_t>(sw);
 }
 
+#if defined(__APPLE__) && defined(__aarch64__)
+template<>
+inline int find_lowest_bit<unsigned long>(unsigned long v) {
+  return find_lowest_bit<uint64_t>(static_cast<uint64_t>(v));
+}
+#endif
+
 class DynamicBitset {
  public:
   using Block = unsigned long;  // NOLINT(runtime/int)
diff -ruN a/MODULE.bazel b/MODULE.bazel
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -0,0 +1,19 @@
+module(
+    name = "behavioral_model",
+    version = "head",
+)
+
+bazel_dep(name = "platforms", version = "0.0.10")
+bazel_dep(name = "rules_cc", version = "0.2.17")
+bazel_dep(name = "boost.container", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.filesystem", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.functional", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.multiprecision", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.program_options", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.thread", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.variant", version = "1.90.0.bcr.1")
+
+# For the bm_dataplane_interface_cc_grpc target — diff-harness only.
+bazel_dep(name = "grpc", version = "1.80.0")
+bazel_dep(name = "protobuf", version = "33.5")
+bazel_dep(name = "rules_proto", version = "7.1.0")
